function buildPlacementOptions(schools: SchoolProfile[], teachers: TeacherProfile[]): PlacementOption[] {
  return teachers.reduce<PlacementOption[]>((acc, teacher) => {
    const school = schools.find((s) => s.id === teacher.schoolId);
    if (school) acc.push({ id: `${school.id}::${teacher.id}`, school, teacher });
    return acc;
  }, []);
}

function isFieldCompatible(student: StudentProfile, option: PlacementOption): { ok: boolean; reasons: string[] } {
  const { school, teacher } = option;
  const failures: string[] = [];

  if (!school.schoolApproved) failures.push("School is not approved.");
  if (!school.approvedClassroomsAvailable) failures.push("Approved classroom is not available.");
  if (!teacher.willingToMentor) failures.push("Teacher is not available/willing to mentor.");
  if (teacher.yearsExperience < 3) failures.push("Teacher has fewer than 3 years of experience.");
  if (!teacher.fieldMatch) failures.push("Teacher is not currently teaching in the candidate's field.");
  if (!student.onlineProgram && school.milesFromCampus > student.distanceFromCampusLimitMiles) failures.push("Site exceeds distance guideline for non-online candidate.");
  if (student.relativeConflictSchoolIds.includes(school.id)) failures.push("Relative employed at placement site.");
  if (student.childAttendsSchoolIds.includes(school.id)) failures.push("Candidate child attends placement site.");
  if (student.conflictSchoolIds.includes(school.id)) failures.push("Conflict flagged by OCE.");
  if (teacher.currentlyAssigned >= teacher.capacity) failures.push("Teacher mentor capacity is full.");
  if (!school.certificationAreasSupported.includes(student.certificationArea) && !school.certificationAreasSupported.includes("Multiple")) failures.push("School does not support the candidate's certification area.");
  if (!(teacher.certificationArea === student.certificationArea || teacher.certificationArea === "Multiple")) failures.push("Teacher certification area does not match candidate field.");
  if (!student.requiredGradeBand.includes(teacher.gradeBand)) failures.push("Placement grade band does not satisfy candidate's required coverage.");

  return { ok: failures.length === 0, reasons: failures };
}

function scorePlacement(student: StudentProfile, option: PlacementOption): MatchResult {
  const { school, teacher } = option;
  const constraint = isFieldCompatible(student, option);
  const scoreBreakdown: { label: string; points: number }[] = [];
  if (!constraint.ok) return { option, eligible: false, score: 0, hardConstraintFailures: constraint.reasons, scoreBreakdown };

  let score = 0;
  const add = (label: string, points: number) => {
    score += points;
    scoreBreakdown.push({ label, points });
  };

  const isNeededBand = !student.placementHistory.includes(teacher.gradeBand) && student.requiredGradeBand.includes(teacher.gradeBand);
  if (isNeededBand) add("Needed grade-band coverage", 30);
  else if (student.preferredGradeBand === teacher.gradeBand) add("Student preferred grade band", 15);

  if (student.preferredMentoringStyle === teacher.mentoringStyle) add("Mentoring style fit", 15);
  else if (student.supportNeed === "High" && teacher.mentoringStyle === "Structured") add("High-support student paired with structured mentor", 10);

  if (student.needsStrongEdTPASupport && teacher.strengths.includes("edTPA")) add("edTPA support match", 12);
  if (student.needsClassroomManagementSupport && teacher.strengths.includes("Classroom Management")) add("Classroom management support match", 12);
  if (student.valuesDiverseSetting && school.diverseSetting) add("Diverse setting preference match", 10);
  if (teacher.classALicensed) add("Preferred advanced licensure", 5);
  if (teacher.nbpts) add("NBPTS credential", 4);
  if (["Elementary Education", "Early Childhood Education", "Collaborative Special Education K-6"].includes(student.certificationArea) && teacher.letrsOrSOR) add("Science-of-reading / LETRS fit", 6);

  const utilization = teacher.currentlyAssigned / Math.max(teacher.capacity, 1);
  if (utilization < 0.5) add("Mentor capacity to support well", 6);
  else if (utilization < 1) add("Mentor capacity to support well", 3);

  if (!student.onlineProgram) add("Reasonable travel fit", school.milesFromCampus <= 10 ? 6 : school.milesFromCampus <= 25 ? 3 : 1);

  if ((student.stage === "Exploration" || student.stage === "Developing Practice") && (teacher.mentoringStyle === "Structured" || teacher.mentoringStyle === "Balanced")) add("Timeline fit for earlier-stage student", 8);
  if (student.stage === "Internship Ready" && teacher.mentoringStyle === "Autonomy-Supportive") add("Timeline fit for internship-ready student", 6);

  return { option, eligible: true, score, hardConstraintFailures: [], scoreBreakdown };
}

function rankPlacements(student: StudentProfile, options: PlacementOption[]) {
  return options.map((option) => scorePlacement(student, option)).sort((a, b) => b.score - a.score);
}

function runSelfTests(): { name: string; passed: boolean; detail: string }[] {
  const options = buildPlacementOptions(sampleSchools, sampleTeachers);
  const student1 = sampleStudents[0];
  const student2 = sampleStudents[1];
  const student3 = sampleStudents[2];
  const oakMountain = options.find((o) => o.school.id === "school-5");
  const avondale = options.find((o) => o.school.id === "school-2");
  const glenIris = options.find((o) => o.school.id === "school-1");
  const huffman = options.find((o) => o.school.id === "school-3");

  const t1 = oakMountain ? isFieldCompatible(student1, oakMountain) : { ok: false, reasons: ["Missing option"] };
  const t2 = avondale ? isFieldCompatible(student2, avondale) : { ok: false, reasons: ["Missing option"] };
  const t3 = glenIris ? isFieldCompatible(student2, glenIris) : { ok: true, reasons: [] };
  const t4 = rankPlacements(student2, options).filter((r) => r.eligible);
  const t5 = huffman ? isFieldCompatible(student3, huffman) : { ok: false, reasons: ["Missing option"] };

  return [
    { name: "Blocks relative-conflict school", passed: !t1.ok && t1.reasons.includes("Relative employed at placement site."), detail: "Student 1 should be blocked from Oak Mountain due to relative conflict." },
    { name: "Allows compatible special education placement", passed: t2.ok, detail: "Student 2 should be eligible for Avondale / Keisha Green." },
    { name: "Blocks wrong certification area", passed: !t3.ok, detail: "Student 2 should be blocked from Glen Iris because certification area does not match." },
    { name: "Ranking returns at least one eligible match", passed: t4.length > 0, detail: "Ranking should produce at least one eligible match for Student 2." },
    { name: "Allows compatible online P-12 ESL placement", passed: t5.ok, detail: "Student 3 should be eligible for Huffman / Luis Carter." },
  ];
}

