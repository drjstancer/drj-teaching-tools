/**
 * Placement Matching Model
 *
 * Build-safe version:
 * - No lucide-react dependency.
 * - No shadcn/ui dependency.
 * - Uses plain React controls and Tailwind classes only.
 *
 * Includes:
 * - Student portal profile
 * - Teacher portal profile; teacher chooses school from prepopulated school profiles
 * - School portal profile; completed by school admin/designee or OCE designee
 * - Editable / confirmable algorithmic matches
 * - Feed payload for downstream compliance tracker
 * - Lightweight self-tests for matching rules
 */

type CandidateStage = "Exploration" | "Developing Practice" | "Pre-Internship" | "Internship Ready";
type CertificationArea =
  | "Elementary Education"
  | "Secondary English"
  | "Collaborative Special Education K-6"
  | "P-12 ESL"
  | "Early Childhood Education";

type MentoringStyle = "Structured" | "Balanced" | "Autonomy-Supportive";
type SupportNeed = "High" | "Moderate" | "Low";
type TeacherStrength = "edTPA" | "Classroom Management" | "Differentiation" | "Science of Reading" | "Family Communication";
type SettingType = "Public P-12" | "Regionally Accredited Private" | "NAEYC Accredited";

type SchoolProfile = {
  id: string;
  schoolName: string;
  district: string;
  settingType: SettingType;
  gradeBandsSupported: string[];
  certificationAreasSupported: (CertificationArea | "Multiple")[];
  milesFromCampus: number;
  diverseSetting: boolean;
  schoolApproved: boolean;
  approvedClassroomsAvailable: boolean;
  additionalRequirements: string;
  capacity: number;
  notes: string;
};

type TeacherProfile = {
  id: string;
  teacherName: string;
  schoolId: string;
  certificationArea: CertificationArea | "Multiple";
  gradeBand: string;
  yearsExperience: number;
  fieldMatch: boolean;
  classALicensed: boolean;
  nbpts: boolean;
  letrsOrSOR: boolean;
  mentoringStyle: MentoringStyle;
  strengths: TeacherStrength[];
  willingToMentor: boolean;
  capacity: number;
  currentlyAssigned: number;
  lastUpdated: string;
  notes: string;
};

type StudentProfile = {
  id: string;
  name: string;
  certificationArea: CertificationArea;
  stage: CandidateStage;
  onlineProgram: boolean;
  preferredGradeBand: string;
  requiredGradeBand: string[];
  distanceFromCampusLimitMiles: number;
  supportNeed: SupportNeed;
  preferredMentoringStyle: MentoringStyle;
  wantsHighStructure: boolean;
  needsStrongEdTPASupport: boolean;
  needsClassroomManagementSupport: boolean;
  valuesDiverseSetting: boolean;
  placementHistory: string[];
  conflictSchoolIds: string[];
  relativeConflictSchoolIds: string[];
  childAttendsSchoolIds: string[];
  notes: string;
};

type PlacementOption = {
  id: string;
  school: SchoolProfile;
  teacher: TeacherProfile;
};

type MatchResult = {
  option: PlacementOption;
  eligible: boolean;
  score: number;
  hardConstraintFailures: string[];
  scoreBreakdown: { label: string; points: number }[];
};

