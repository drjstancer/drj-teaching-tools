export default function PlacementMatchingModel() {
  const [schools, setSchools] = useState<SchoolProfile[]>(sampleSchools);
  const [teachers, setTeachers] = useState<TeacherProfile[]>(sampleTeachers);
  const [studentId, setStudentId] = useState(sampleStudents[0].id);
  const [confirmedOptionId, setConfirmedOptionId] = useState<string | null>(null);
  const [manualOverride, setManualOverride] = useState<string>("");
  const [teacherPortalId, setTeacherPortalId] = useState(sampleTeachers[0].id);
  const [schoolPortalId, setSchoolPortalId] = useState(sampleSchools[0].id);
  const [teacherDraft, setTeacherDraft] = useState<TeacherProfile>({ ...sampleTeachers[0] });
  const [schoolDraft, setSchoolDraft] = useState<SchoolProfile>({ ...sampleSchools[0] });
  const [activeTab, setActiveTab] = useState("portals");

  const student = sampleStudents.find((s) => s.id === studentId) ?? sampleStudents[0];
  const placementOptions = useMemo(() => buildPlacementOptions(schools, teachers), [schools, teachers]);
  const ranked = useMemo(() => rankPlacements(student, placementOptions), [student, placementOptions]);
  const recommended = ranked.find((m) => m.eligible);
  const confirmed = placementOptions.find((p) => p.id === confirmedOptionId);
  const overrideOption = placementOptions.find((p) => p.id === manualOverride);
  const selfTests = useMemo(() => runSelfTests(), []);

  const feedPayload = useMemo(() => {
    const chosen = overrideOption ?? confirmed ?? recommended?.option ?? null;
    if (!chosen) return null;
    return {
      studentId: student.id,
      studentName: student.name,
      certificationArea: student.certificationArea,
      stage: student.stage,
      selectedSchoolId: chosen.school.id,
      schoolName: chosen.school.schoolName,
      teacherId: chosen.teacher.id,
      cooperatingTeacher: chosen.teacher.teacherName,
      gradeBand: chosen.teacher.gradeBand,
      district: chosen.school.district,
      matchSource: overrideOption ? "manual_override" : confirmed ? "human_confirmed_recommendation" : "algorithmic_recommendation",
      requiresHumanReview: !(confirmed || overrideOption),
    };
  }, [student, confirmed, overrideOption, recommended]);

  const onStudentChange = (value: string) => {
    setStudentId(value);
    setConfirmedOptionId(null);
    setManualOverride("");
  };

  const onTeacherPortalChange = (teacherId: string) => {
    setTeacherPortalId(teacherId);
    const teacher = teachers.find((t) => t.id === teacherId);
    if (teacher) setTeacherDraft({ ...teacher });
  };

  const onSchoolPortalChange = (schoolId: string) => {
    setSchoolPortalId(schoolId);
    const school = schools.find((s) => s.id === schoolId);
    if (school) setSchoolDraft({ ...school });
  };

  const saveTeacherProfile = () => {
    setTeachers((prev) => prev.map((t) => (t.id === teacherDraft.id ? { ...teacherDraft, lastUpdated: "Today" } : t)));
  };

  const saveSchoolProfile = () => {
    setSchools((prev) => prev.map((s) => (s.id === schoolDraft.id ? { ...schoolDraft } : s)));
  };

  const tabs = [
    { id: "portals", label: "Portal Layer" },
    { id: "matching", label: "Matching Engine" },
    { id: "integration", label: "Tracking Feed" },
    { id: "tests", label: "Self-Tests" },
  ];

  return (
    <div className="min-h-screen bg-slate-50 p-6 md:p-8">
      <div className="mx-auto max-w-7xl space-y-6">
        <div className="rounded-3xl bg-gradient-to-r from-emerald-900 via-emerald-800 to-green-700 p-8 text-white shadow-lg">
          <div className="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <div className="text-sm uppercase tracking-[0.18em] text-emerald-100">Interview Demo Model</div>
              <h1 className="mt-2 text-3xl font-semibold md:text-4xl">Placement Matching System</h1>
              <p className="mt-3 max-w-4xl text-sm text-emerald-50/95 md:text-base">
                Linked student, teacher, and school portals feed a placement matching engine. Teachers select their school from a prepopulated school list, can return later to update their profile, and all recommendations remain editable and human-confirmable.
              </p>
            </div>
            <div className="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur-sm">
              <div className="text-sm text-emerald-100">Core rule</div>
              <div className="font-medium">Hard constraints first. Best-fit scoring second. Human confirmation always.</div>
            </div>
          </div>
        </div>

        <div className="grid gap-4 md:grid-cols-4">
          <CardBox className="rounded-2xl p-5"><div className="text-sm text-slate-500">School profiles</div><div className="text-3xl font-semibold">{schools.length}</div></CardBox>
          <CardBox className="rounded-2xl p-5"><div className="text-sm text-slate-500">Teacher profiles</div><div className="text-3xl font-semibold">{teachers.length}</div></CardBox>
          <CardBox className="rounded-2xl p-5"><div className="text-sm text-slate-500">Eligible matches</div><div className="text-3xl font-semibold">{ranked.filter((r) => r.eligible).length}</div></CardBox>
          <CardBox className="rounded-2xl p-5"><div className="text-sm text-slate-500">Human decision state</div><div className="text-3xl font-semibold">{confirmed || overrideOption ? "Confirmed" : "Pending"}</div></CardBox>
        </div>

        <div className="flex flex-wrap gap-2 rounded-2xl bg-white p-2 shadow-sm">
          {tabs.map((tab) => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id)} className={`rounded-xl px-4 py-2 text-sm font-medium ${activeTab === tab.id ? "bg-emerald-700 text-white" : "text-slate-700 hover:bg-slate-100"}`}>
              {tab.label}
            </button>
          ))}
        </div>

        {activeTab === "portals" && (
          <div className="grid gap-6 lg:grid-cols-3">
            <CardBox>
              <CardHeaderBox icon="S" title="Student Portal" description="Student completes a profile that informs timeline-aware matching." />
              <div className="space-y-4 p-5">
                <div>
                  <LabelText>Student</LabelText>
                  <SelectBox value={studentId} onChange={(e) => onStudentChange(e.target.value)}>
                    {sampleStudents.map((s) => <option key={s.id} value={s.id}>{s.name} — {s.certificationArea}</option>)}
