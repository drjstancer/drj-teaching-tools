                </div>
                <div className="rounded-2xl border bg-slate-50 p-4">
                  <div className="font-semibold text-slate-900">{student.name}</div>
                  <div className="text-sm text-slate-500">{student.certificationArea} • {student.stage}</div>
                  <div className="mt-3 flex flex-wrap gap-2">
                    <Pill>Support need: {student.supportNeed}</Pill>
                    <Pill>Mentor style: {student.preferredMentoringStyle}</Pill>
                    <Pill>Preferred band: {student.preferredGradeBand}</Pill>
                  </div>
                </div>
                <PortalQuestionList questions={intakeQuestions.student} />
              </div>
            </CardBox>

            <CardBox>
              <CardHeaderBox icon="T" title="Teacher Portal" description="Teacher selects a school from the prepopulated school list and can return to update their profile later." />
              <div className="space-y-4 p-5">
                <div>
                  <LabelText>Teacher Profile</LabelText>
                  <SelectBox value={teacherPortalId} onChange={(e) => onTeacherPortalChange(e.target.value)}>
                    {teachers.map((t) => <option key={t.id} value={t.id}>{t.teacherName}</option>)}
                  </SelectBox>
                </div>
                <div>
                  <LabelText>Teacher Name</LabelText>
                  <InputText value={teacherDraft.teacherName} onChange={(e) => setTeacherDraft({ ...teacherDraft, teacherName: e.target.value })} />
                </div>
                <div>
                  <LabelText>School from prepopulated school profiles</LabelText>
                  <SelectBox value={teacherDraft.schoolId} onChange={(e) => setTeacherDraft({ ...teacherDraft, schoolId: e.target.value })}>
                    {schools.map((s) => <option key={s.id} value={s.id}>{s.schoolName} — {s.district}</option>)}
                  </SelectBox>
                </div>
                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <LabelText>Mentoring Style</LabelText>
                    <SelectBox value={teacherDraft.mentoringStyle} onChange={(e) => setTeacherDraft({ ...teacherDraft, mentoringStyle: e.target.value as MentoringStyle })}>
                      <option value="Structured">Structured</option>
                      <option value="Balanced">Balanced</option>
                      <option value="Autonomy-Supportive">Autonomy-Supportive</option>
                    </SelectBox>
                  </div>
                  <div>
                    <LabelText>Capacity</LabelText>
                    <InputText type="number" min={0} value={teacherDraft.capacity} onChange={(e) => setTeacherDraft({ ...teacherDraft, capacity: Number(e.target.value) || 0 })} />
                  </div>
                </div>
                <label className="flex items-center gap-2 text-sm text-slate-700">
                  <input type="checkbox" checked={teacherDraft.willingToMentor} onChange={(e) => setTeacherDraft({ ...teacherDraft, willingToMentor: e.target.checked })} />
                  Willing to mentor this term
                </label>
                <div>
                  <LabelText>Teacher Notes</LabelText>
                  <TextAreaBox value={teacherDraft.notes} onChange={(e) => setTeacherDraft({ ...teacherDraft, notes: e.target.value })} />
                </div>
                <ButtonBox onClick={saveTeacherProfile}>Save teacher profile update</ButtonBox>
                <PortalQuestionList questions={intakeQuestions.teacher} />
              </div>
            </CardBox>

            <CardBox>
              <CardHeaderBox icon="P" title="School Portal" description="Completed by school admin/designee or OCE designee." />
              <div className="space-y-4 p-5">
                <div>
                  <LabelText>School Profile</LabelText>
                  <SelectBox value={schoolPortalId} onChange={(e) => onSchoolPortalChange(e.target.value)}>
                    {schools.map((s) => <option key={s.id} value={s.id}>{s.schoolName}</option>)}
                  </SelectBox>
                </div>
                <div>
                  <LabelText>School Name</LabelText>
                  <InputText value={schoolDraft.schoolName} onChange={(e) => setSchoolDraft({ ...schoolDraft, schoolName: e.target.value })} />
                </div>
                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <LabelText>District</LabelText>
                    <InputText value={schoolDraft.district} onChange={(e) => setSchoolDraft({ ...schoolDraft, district: e.target.value })} />
                  </div>
                  <div>
                    <LabelText>Miles from campus</LabelText>
                    <InputText type="number" min={0} value={schoolDraft.milesFromCampus} onChange={(e) => setSchoolDraft({ ...schoolDraft, milesFromCampus: Number(e.target.value) || 0 })} />
                  </div>
                </div>
                <label className="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" checked={schoolDraft.schoolApproved} onChange={(e) => setSchoolDraft({ ...schoolDraft, schoolApproved: e.target.checked })} />Approved placement site</label>
                <label className="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" checked={schoolDraft.approvedClassroomsAvailable} onChange={(e) => setSchoolDraft({ ...schoolDraft, approvedClassroomsAvailable: e.target.checked })} />Approved classroom available</label>
                <div>
                  <LabelText>Additional Site Requirements</LabelText>
                  <TextAreaBox value={schoolDraft.additionalRequirements} onChange={(e) => setSchoolDraft({ ...schoolDraft, additionalRequirements: e.target.value })} />
                </div>
                <ButtonBox onClick={saveSchoolProfile}>Save school profile update</ButtonBox>
                <PortalQuestionList questions={intakeQuestions.school} />
              </div>
            </CardBox>
          </div>
        )}

        {activeTab === "matching" && (
          <div className="space-y-6">
            <div className="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
              <CardBox>
                <CardHeaderBox icon="M" title="Matching Logic Summary" description="The model combines handbook constraints with sample fit variables." />
                <div className="grid gap-4 p-5">
                  <div className="rounded-2xl border p-4"><div className="font-semibold text-slate-900">Hard constraints</div><ul className="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700"><li>Approved school / classroom only</li><li>Teacher has at least 3 years of experience</li><li>Teacher is in student field</li><li>Grade-band requirement is satisfied</li><li>Distance guideline for non-online programs</li><li>No relative / child-at-site conflicts</li></ul></div>
                  <div className="rounded-2xl border p-4"><div className="font-semibold text-slate-900">Fit variables</div><ul className="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700"><li>Student development stage</li><li>Mentoring style preference</li><li>edTPA support strength</li><li>Classroom-management support</li><li>Diversity exposure value</li><li>Mentor capacity / workload</li></ul></div>
                  <div className="rounded-2xl border bg-slate-50 p-4"><div className="font-semibold text-slate-900">Current student</div><div className="mt-2 text-sm text-slate-700">{student.name} — {student.certificationArea} — {student.stage}</div><div className="mt-3 flex flex-wrap gap-2"><Pill>Required bands: {student.requiredGradeBand.join(" + ")}</Pill><Pill>Support: {student.supportNeed}</Pill><Pill>Mentor style: {student.preferredMentoringStyle}</Pill></div></div>
                </div>
              </CardBox>

              <CardBox>
                <CardHeaderBox icon="R" title="Match Results" description="Algorithm selects; humans confirm or override." />
                <div className="space-y-4 p-5">
                  {recommended ? <div className="rounded-2xl border border-emerald-200 bg-emerald-50 p-4"><div className="flex items-start justify-between gap-4"><div><div className="text-sm uppercase tracking-wide text-emerald-700">Top algorithmic recommendation</div><div className="mt-1 text-xl font-semibold text-slate-900">{recommended.option.school.schoolName} — {recommended.option.teacher.teacherName}</div><div className="text-sm text-slate-600">{recommended.option.teacher.gradeBand} • {recommended.option.school.district}</div></div><StatusBadge>Score {recommended.score}</StatusBadge></div><div className="mt-3 flex flex-wrap gap-2"><Pill>{recommended.option.teacher.mentoringStyle} mentor</Pill><Pill>{recommended.option.school.milesFromCampus} miles</Pill>{recommended.option.teacher.classALicensed ? <Pill>Class A</Pill> : null}{recommended.option.teacher.nbpts ? <Pill>NBPTS</Pill> : null}{recommended.option.teacher.letrsOrSOR ? <Pill>LETRS / SOR</Pill> : null}</div></div> : <div className="rounded-2xl border border-amber-200 bg-amber-50 p-4">No eligible placement found under current rules.</div>}

                  <div className="space-y-3">
                    {ranked.map((result) => <div key={result.option.id} className={`rounded-2xl border p-4 ${result.eligible ? "bg-white" : "bg-slate-50"}`}><div className="flex items-start justify-between gap-4"><div><div className="font-semibold text-slate-900">{result.option.school.schoolName}</div><div className="text-sm text-slate-500">{result.option.teacher.teacherName} • {result.option.teacher.gradeBand} • {result.option.teacher.certificationArea}</div></div>{result.eligible ? <StatusBadge>Eligible • {result.score}</StatusBadge> : <StatusBadge tone="amber">Blocked</StatusBadge>}</div>{result.eligible ? <div className="mt-3 grid gap-2 text-sm text-slate-700">{result.scoreBreakdown.map((item) => <div key={item.label} className="flex items-center justify-between rounded-xl bg-slate-50 px-3 py-2"><span>{item.label}</span><span className="font-medium">+{item.points}</span></div>)}</div> : <div className="mt-3 rounded-xl border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900"><div className="font-medium">Hard constraint failures</div><ul className="mt-2 list-disc space-y-1 pl-5">{result.hardConstraintFailures.map((r) => <li key={r}>{r}</li>)}</ul></div>}</div>)}
                  </div>
                </div>
              </CardBox>
            </div>

            <div className="grid gap-6 lg:grid-cols-2">
              <CardBox>
                <CardHeaderBox icon="H" title="Human Confirmation & Override" description="Algorithm selects; humans confirm or change with rationale." />
                <div className="space-y-4 p-5">
                  <div><LabelText>Manual override placement</LabelText><SelectBox value={manualOverride || "none"} onChange={(e) => setManualOverride(e.target.value === "none" ? "" : e.target.value)}><option value="none">No override</option>{placementOptions.map((p) => <option key={p.id} value={p.id}>{p.school.schoolName} — {p.teacher.teacherName}</option>)}</SelectBox></div>
                  <div className="flex flex-wrap gap-3">{recommended ? <ButtonBox onClick={() => setConfirmedOptionId(recommended.option.id)}>Confirm algorithm recommendation</ButtonBox> : null}<ButtonBox variant="outline" onClick={() => setConfirmedOptionId(null)}>Clear confirmation</ButtonBox></div>
                  <div className="rounded-2xl border bg-slate-50 p-4"><div className="font-semibold text-slate-900">Decision snapshot</div><div className="mt-2 text-sm text-slate-700">{overrideOption ? `Manual override selected: ${overrideOption.school.schoolName} — ${overrideOption.teacher.teacherName}` : confirmed ? `Human-confirmed recommendation: ${confirmed.school.schoolName} — ${confirmed.teacher.teacherName}` : "No human confirmation yet. Recommendation remains pending review."}</div></div>
                </div>
              </CardBox>

              <CardBox>
                <CardHeaderBox icon="F" title="Portal-to-Matching Flow" description="The profiles feed the engine; the reviewed match feeds the compliance tracker." />
                <div className="space-y-3 p-5 text-sm text-slate-700"><div className="rounded-xl border bg-white p-3">School portal creates the approved school list.</div><div className="rounded-xl border bg-white p-3">Teacher portal selects school from that prepopulated list and updates mentor attributes over time.</div><div className="rounded-xl border bg-white p-3">Student portal captures support needs, conflicts, and developmental stage.</div><div className="rounded-xl border bg-white p-3">Matching engine recommends placements using constraints + fit logic.</div><div className="rounded-xl border bg-white p-3">OCE confirms or overrides the recommendation and sends the final assignment to the tracking system.</div></div>
              </CardBox>
            </div>
          </div>
        )}

        {activeTab === "integration" && (
          <CardBox>
            <CardHeaderBox icon="D" title="Feed into Compliance / Tracking System" description="Example of what this module would pass to the downstream tracker after review." />
            <div className="p-5"><pre className="overflow-auto rounded-2xl bg-slate-950 p-4 text-sm text-slate-100">{JSON.stringify(feedPayload, null, 2)}</pre></div>
          </CardBox>
        )}

        {activeTab === "tests" && (
          <CardBox>
            <CardHeaderBox icon="✓" title="Matching Logic Self-Tests" description="Lightweight validation checks for the model's core rules." />
            <div className="space-y-3 p-5">
              {selfTests.map((test) => <div key={test.name} className="flex items-start justify-between gap-4 rounded-2xl border bg-white p-4"><div><div className="font-semibold text-slate-900">{test.name}</div><div className="text-sm text-slate-600">{test.detail}</div></div><StatusBadge tone={test.passed ? "green" : "red"}>{test.passed ? "Passed" : "Failed"}</StatusBadge></div>)}
            </div>
          </CardBox>
        )}
      </div>
    </div>
  );
}
